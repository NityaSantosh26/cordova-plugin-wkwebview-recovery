<plugin id="cordova-plugin-wk-route-recovery" version="1.0.0"
        xmlns="http://apache.org/cordova/ns/plugins"
        xmlns:android="http://schemas.android.com/apk/res/android">
    <name>WK Route Recovery</name>

    <js-module src="www/WKRouteRecovery.js" name="WKRouteRecovery">
        <clobbers target="cordova.WKRouteRecovery" />
    </js-module>

    <platform name="ios">
        <source-file src="src/ios/WKRouteRecovery.m" />
        <config-file target="config.xml" parent="/*">
            <feature name="WKRouteRecovery">
                <param name="ios-package" value="WKRouteRecovery" />
            </feature>
        </config-file>
    </platform>
</plugin>
